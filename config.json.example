{
  "api_mode": "batch",
  "active_model": "gemini-3.1-flash-lite-preview",
  "batch_chunk_size": 5000,
  "standard_club_size": 250,
  "upload_threads": 50,
  "source_dir": "/path/to/WhatsApp/Media",
  "output_dir": "/path/to/Sorted",
  "features": {
    "restore_exif_date": true
  },
  "ignored_extensions": [],
  "pricing": {
    "gemini-3.1-flash-lite-preview": {
      "input_per_1m": 0.25,
      "output_per_1m": 1.50
    },
    "gemini-3-flash-preview": {
      "input_per_1m": 0.50,
      "output_per_1m": 3.00
    },
    "gemini-2.5-flash-lite": {
      "input_per_1m": 0.10,
      "output_per_1m": 0.40
    }
  },
  "currency": {
    "symbol": "₹",
    "usd_exchange_rate": 83.50
  },
  "fallback_category": "Uncategorized_Review",
  "global_rules": [
    "Classify the main subject into exactly ONE category.",
    "If ambiguous or unsure, return Uncategorized_Review."
  ],
  "whatsapp_categories": [
    {
      "name": "People_Portraits",
      "description": "1-2 people, selfies, close-up portraits."
    },
    {
      "name": "People_Group_Photos",
      "description": "3+ people, families, crowds, events, gatherings."
    },
    {
      "name": "Documents_Important",
      "description": "IDs, receipts, invoices, bills, prescriptions, forms, printed text."
    },
    {
      "name": "Personal_NonPeople_Photos",
      "description": "Pets, food, travel, objects, nature, vehicles, architecture."
    },
    {
      "name": "Screenshots_Chat_UI",
      "description": "Screenshots, app UI, web pages, chat logs, QR codes."
    },
    {
      "name": "Memes_Forwards_Graphics",
      "description": "Memes, quote cards, greeting cards, jokes, digital posters, forwards."
    }
  ]
}
